# PostgreSQL
POSTGRES_DSN=postgres://user:pass@postgres:5432/dbname

# MinIO / S3-compatible storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=scans

# SFTP scan directory (base dir that contains one subdir per printer)
SFTP_SCAN_BASE_DIR=/srv/scans/incoming

# OCR settings
OCR_LANG=por
OCR_DPI=300

# Webhook to notify the NestJS API after each scan is processed
SCAN_WEBHOOK_URL=
SCAN_WEBHOOK_SECRET=

# Worker settings
MAX_CONCURRENT=5       # max PDFs processed simultaneously
MAX_FILE_SIZE_MB=50    # files larger than this are rejected

# Logging
LOG_LEVEL=INFO
