# ─────────────────────────────────────────
# Ambiente
# ─────────────────────────────────────────
# Valores válidos: development | production
NODE_ENV=development
APP_PORT=3000

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=manutencao_user
# Gere com: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=manutencao_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL usada pelo Prisma (substitua user, password, host, port e db)
DATABASE_URL="postgresql://manutencao_user:SENHA@localhost:5432/manutencao_db?schema=public"

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Gere com: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────
# MinIO (armazenamento de arquivos)
# ─────────────────────────────────────────
MINIO_ROOT_USER=minio_admin
# Gere com: openssl rand -base64 32
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
# Em produção use true (HTTPS)
MINIO_USE_SSL=false

# ─────────────────────────────────────────
# Buckets MinIO
# ─────────────────────────────────────────
MINIO_BUCKET_EQUIPMENT=equipment-attachments
MINIO_BUCKET_SERVICE_ORDERS=service-order-attachments
MINIO_BUCKET_INVOICES=invoices
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_REPORTS=reports
# colocar a variavel de URL pública do MinIO (deve apontar para o proxy Nginx em produção, e pode ficar vazia no desenvolvimento)
MINIO_PUBLIC_URL=
# ─────────────────────────────────────────
# JWT / Auth
# ─────────────────────────────────────────
# OBRIGATÓRIO — Gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=
# OBRIGATÓRIO — Gere com: openssl rand -hex 32 (use valor diferente do ACCESS)
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────
# CORS (origens permitidas separadas por vírgula)
# ─────────────────────────────────────────
# Exemplo produção: ALLOWED_ORIGINS=https://app.suaempresa.com
ALLOWED_ORIGINS=http://localhost:3001

# ─────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seu_email@gmail.com
# Para Gmail use uma App Password: https://myaccount.google.com/apppasswords
MAIL_PASSWORD=
MAIL_FROM_NAME=Sistema de Manutenção
MAIL_FROM_ADDRESS=seu_email@gmail.com
MAIL_IGNORE_TLS=false

# ─────────────────────────────────────────
# Telegram (opcional)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=ManutencaoBot
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=

# ─────────────────────────────────────────
# Ferramentas (apenas desenvolvimento)
# ─────────────────────────────────────────
REDIS_INSIGHT_PORT=5540
