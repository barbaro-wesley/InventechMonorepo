generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Platform {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  companies Company[]

  @@map("platforms")
}

model Company {
  id                   String               @id @default(uuid())
  platformId           String               @map("platform_id")
  name                 String
  slug                 String               @unique
  document             String?              @unique
  email                String?
  phone                String?
  logoUrl              String?              @map("logo_url")
  status               CompanyStatus        @default(ACTIVE)
  trialEndsAt          DateTime?            @map("trial_ends_at")
  settings             Json?
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")
  reportFooterText     String?              @map("report_footer_text")
  reportHeaderTitle    String?              @map("report_header_title")
  reportPrimaryColor   String?              @default("#1E40AF") @map("report_primary_color")
  reportSecondaryColor String?              @default("#DBEAFE") @map("report_secondary_color")
  licenseExpiresAt     DateTime?
  suspendedAt          DateTime?
  suspendedBy          String?
  suspendedReason      String?
  street               String?              @map("street")
  number               String?              @map("number")
  complement           String?              @map("complement")
  neighborhood         String?              @map("neighborhood")
  city                 String?              @map("city")
  state                String?              @map("state")
  zipCode              String?              @map("zip_code")
  enforce2FAForAll     Boolean              @default(false) @map("enforce_2fa_for_all")
  clients              Client[]
  platform             Platform             @relation(fields: [platformId], references: [id])
  customRoles          CustomRole[]
  maintenanceGroups    MaintenanceGroup[]
  reportPermissions    ReportPermission[]
  resourcePermissions  ResourcePermission[]
  users                User[]
  alertRules            AlertRule[]
  notificationConfigs   NotificationConfig[]
  eSignDocuments        ESignDocument[]
  laudoTemplates        LaudoTemplate[]
  laudos                Laudo[]

  @@index([platformId])
  @@index([slug])
  @@index([status])
  @@map("companies")
}

model Client {
  id                   String                   @id @default(uuid())
  companyId            String                   @map("company_id")
  name                 String
  document             String?
  email                String?
  phone                String?
  address              Json?
  status               ClientStatus             @default(ACTIVE)
  settings             Json?
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  deletedAt            DateTime?                @map("deleted_at")
  logoUrl              String?                  @map("logo_url")
  reportName           String?                  @map("report_name")
  maintenanceGroups    ClientMaintenanceGroup[]
  company              Company                  @relation(fields: [companyId], references: [id])
  maintenanceSchedules MaintenanceSchedule[]
  maintenances         Maintenance[]
  serviceOrders        ServiceOrder[]
  users                User[]
  laudos               Laudo[]
  laudoTemplates       LaudoTemplate[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("clients")
}

model User {
  id                      String                      @id @default(uuid())
  companyId               String?                     @map("company_id")
  clientId                String?                     @map("client_id")
  name                    String
  email                   String                      @unique
  passwordHash            String                      @map("password_hash")
  role                    UserRole
  status                  UserStatus                  @default(ACTIVE)
  avatarUrl               String?                     @map("avatar_url")
  phone                   String?
  telegramChatId          String?                     @map("telegram_chat_id")
  lastLoginAt             DateTime?                   @map("last_login_at")
  lastLoginIp             String?                     @map("last_login_ip")
  createdAt               DateTime                    @default(now()) @map("created_at")
  updatedAt               DateTime                    @updatedAt @map("updated_at")
  deletedAt               DateTime?                   @map("deleted_at")
  customRoleId            String?                     @map("custom_role_id")
  require2FA              Boolean                     @default(false) @map("require_2fa")
  accountBlocks           AccountBlock[]
  emailVerifications      EmailVerification[]
  movementsApproved       EquipmentMovement[]         @relation("MovementApprover")
  movementsRequested      EquipmentMovement[]         @relation("MovementRequester")
  loginAttempts           LoginAttempt[]
  maintenancesExecuted    Maintenance[]
  notifications           Notification[]
  passwordResets          PasswordReset[]
  refreshTokens           RefreshToken[]
  comments                ServiceOrderComment[]
  statusHistoryChanges    ServiceOrderStatusHistory[]
  taskAssignments         ServiceOrderTask[]
  serviceOrderTechnicians ServiceOrderTechnician[]
  serviceOrdersApproved   ServiceOrder[]              @relation("ServiceOrderApprover")
  serviceOrdersOwned      ServiceOrder[]              @relation("ServiceOrderRequester")
  technicianGroups        TechnicianGroup[]
  twoFactorCodes          TwoFactorCode[]
  alertRulesCreated       AlertRule[]
  eSignDocumentsCreated   ESignDocument[]             @relation("ESignDocumentCreatedBy")
  eSignRequestsSigner     ESignRequest[]              @relation("ESignRequestSigner")
  laudoTemplatesCreated   LaudoTemplate[]             @relation("LaudoTemplateCreatedBy")
  laudosCreated           Laudo[]                     @relation("LaudoCreatedBy")
  laudosAsTechnician      Laudo[]                     @relation("LaudoTechnician")
  laudosApproved          Laudo[]                     @relation("LaudoApprovedBy")
  client                  Client?                     @relation(fields: [clientId], references: [id])
  company                 Company?                    @relation(fields: [companyId], references: [id])
  customRole              CustomRole?                 @relation(fields: [customRoleId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([companyId, clientId])
  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model MaintenanceGroup {
  id             String                   @id @default(uuid())
  companyId      String                   @map("company_id")
  name           String
  description    String?
  color          String?
  isActive       Boolean                  @default(true) @map("is_active")
  noRestriction  Boolean                  @default(false) @map("no_restriction")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  clientGroups   ClientMaintenanceGroup[]
  equipmentTypes EquipmentType[]
  company        Company                  @relation(fields: [companyId], references: [id])
  schedules      MaintenanceSchedule[]
  serviceOrders  ServiceOrder[]
  technicians    TechnicianGroup[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@map("maintenance_groups")
}

model TechnicianGroup {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  groupId    String           @map("group_id")
  isActive   Boolean          @default(true) @map("is_active")
  assignedAt DateTime         @default(now()) @map("assigned_at")
  group      MaintenanceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, isActive])
  @@map("technician_groups")
}

model ClientMaintenanceGroup {
  id         String           @id @default(uuid())
  clientId   String           @map("client_id")
  groupId    String           @map("group_id")
  isActive   Boolean          @default(true) @map("is_active")
  assignedAt DateTime         @default(now()) @map("assigned_at")
  client     Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group      MaintenanceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([clientId, groupId])
  @@index([groupId, isActive])
  @@map("client_maintenance_groups")
}

model CostCenter {
  id          String      @id @default(uuid())
  companyId   String      @map("company_id")
  name        String
  code        String?
  description String?
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  equipments     Equipment[]
  locations      Location[]
  serviceOrders  ServiceOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("cost_centers")
}

model Location {
  id                String              @id @default(uuid())
  companyId         String              @map("company_id")
  name              String
  parentId          String?             @map("parent_id")
  description       String?
  isActive          Boolean             @default(true) @map("is_active")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  costCenterId      String?             @map("cost_center_id")
  movementsTo       EquipmentMovement[] @relation("MovementDestination")
  movementsFrom     EquipmentMovement[] @relation("MovementOrigin")
  currentEquipments Equipment[]         @relation("CurrentLocation")
  equipments        Equipment[]
  serviceOrders     ServiceOrder[]
  costCenter        CostCenter?         @relation(fields: [costCenterId], references: [id])
  parent            Location?           @relation("LocationHierarchy", fields: [parentId], references: [id])
  children          Location[]          @relation("LocationHierarchy")

  @@index([companyId])
  @@index([companyId, parentId])
  @@index([companyId, costCenterId])
  @@map("locations")
}

model EquipmentType {
  id          String             @id @default(uuid())
  companyId   String             @map("company_id")
  name        String
  description String?
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  groupId     String?            @map("group_id")
  subtypes    EquipmentSubtype[]
  group       MaintenanceGroup?  @relation(fields: [groupId], references: [id])
  equipments  Equipment[]

  @@index([companyId])
  @@index([groupId])
  @@map("equipment_types")
}

model EquipmentSubtype {
  id          String        @id @default(uuid())
  typeId      String        @map("type_id")
  companyId   String        @map("company_id")
  name        String
  description String?
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  type        EquipmentType @relation(fields: [typeId], references: [id])
  equipments  Equipment[]

  @@index([typeId])
  @@index([companyId])
  @@map("equipment_subtypes")
}

model Equipment {
  id                   String                @id @default(uuid())
  companyId            String                @map("company_id")
  costCenterId         String?               @map("cost_center_id")
  locationId           String?               @map("location_id")
  currentLocationId    String?               @map("current_location_id")
  typeId               String?               @map("type_id")
  subtypeId            String?               @map("subtype_id")
  name                 String
  brand                String?
  model                String?
  serialNumber         String?               @map("serial_number")
  patrimonyNumber      String?               @map("patrimony_number")
  anvisaNumber         String?               @map("anvisa_number")
  purchaseValue        Decimal?              @map("purchase_value") @db.Decimal(12, 2)
  purchaseDate         DateTime?             @map("purchase_date") @db.Date
  invoiceNumber        String?               @map("invoice_number")
  warrantyStart        DateTime?             @map("warranty_start") @db.Date
  warrantyEnd          DateTime?             @map("warranty_end") @db.Date
  depreciationRate     Decimal?              @map("depreciation_rate") @db.Decimal(5, 2)
  currentValue         Decimal?              @map("current_value") @db.Decimal(12, 2)
  lastDepreciationCalc DateTime?             @map("last_depreciation_calc")
  ipAddress            String?               @map("ip_address")
  operatingSystem      String?               @map("operating_system")
  btus                 Int?
  voltage              String?
  power                String?
  status               EquipmentStatus       @default(ACTIVE)
  criticality          EquipmentCriticality  @default(MEDIUM)
  observations         String?
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  lastMaintenanceAt    DateTime?             @map("last_maintenance_at")
  totalServiceOrders   Int                   @default(0) @map("total_service_orders")
  attachments          Attachment[]          @relation("EquipmentAttachments")
  movements            EquipmentMovement[]
  costCenter           CostCenter?           @relation(fields: [costCenterId], references: [id])
  currentLocation      Location?             @relation("CurrentLocation", fields: [currentLocationId], references: [id])
  location             Location?             @relation(fields: [locationId], references: [id])
  subtype              EquipmentSubtype?     @relation(fields: [subtypeId], references: [id])
  type                 EquipmentType?        @relation(fields: [typeId], references: [id])
  schedules            MaintenanceSchedule[]
  maintenances         Maintenance[]
  serviceOrders        ServiceOrder[]

  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, typeId])
  @@index([serialNumber])
  @@index([patrimonyNumber])
  @@map("equipments")
}

model MaintenanceSchedule {
  id                   String            @id @default(uuid())
  companyId            String            @map("company_id")
  equipmentId          String            @map("equipment_id")
  title                String
  description          String?
  maintenanceType      MaintenanceType   @map("maintenance_type")
  recurrenceType       RecurrenceType    @map("recurrence_type")
  customIntervalDays   Int?              @map("custom_interval_days")
  estimatedDurationMin Int?              @map("estimated_duration_min")
  assignedTechnicianId String?           @map("assigned_technician_id")
  startDate            DateTime          @map("start_date") @db.Date
  endDate              DateTime?         @map("end_date") @db.Date
  nextRunAt            DateTime          @map("next_run_at")
  lastRunAt            DateTime?         @map("last_run_at")
  isActive             Boolean           @default(true) @map("is_active")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  groupId              String?           @map("group_id")
  clientId             String?           @map("client_id")
  client               Client?           @relation(fields: [clientId], references: [id])
  equipment            Equipment         @relation(fields: [equipmentId], references: [id])
  group                MaintenanceGroup? @relation(fields: [groupId], references: [id])
  maintenances         Maintenance[]

  @@index([companyId])
  @@index([companyId, clientId])
  @@index([nextRunAt, isActive])
  @@index([equipmentId])
  @@map("maintenance_schedules")
}

model Maintenance {
  id            String               @id @default(uuid())
  companyId     String               @map("company_id")
  clientId      String?              @map("client_id")
  equipmentId   String               @map("equipment_id")
  scheduleId    String?              @map("schedule_id")
  technicianId  String?              @map("technician_id")
  type          MaintenanceType
  title         String
  description   String?
  scheduledAt   DateTime?            @map("scheduled_at")
  startedAt     DateTime?            @map("started_at")
  completedAt   DateTime?            @map("completed_at")
  observations  String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  attachments   Attachment[]         @relation("MaintenanceAttachments")
  client        Client?              @relation(fields: [clientId], references: [id])
  equipment     Equipment            @relation(fields: [equipmentId], references: [id])
  schedule      MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  technician    User?                @relation(fields: [technicianId], references: [id])
  serviceOrders ServiceOrder[]
  laudos        Laudo[]

  @@index([companyId])
  @@index([companyId, clientId])
  @@index([equipmentId])
  @@index([scheduleId])
  @@index([technicianId])
  @@map("maintenances")
}

model ServiceOrder {
  id              String                      @id @default(uuid())
  companyId       String                      @map("company_id")
  clientId        String?                     @map("client_id")
  equipmentId     String?                     @map("equipment_id")
  costCenterId    String?                     @map("cost_center_id")
  locationId      String?                     @map("location_id")
  maintenanceId   String?                     @map("maintenance_id")
  requesterId     String                      @map("requester_id")
  number          Int
  title           String
  description     String
  status          ServiceOrderStatus          @default(OPEN)
  priority        ServiceOrderPriority        @default(MEDIUM)
  resolution      String?
  internalNotes   String?                     @map("internal_notes")
  estimatedHours  Decimal?                    @map("estimated_hours") @db.Decimal(6, 2)
  actualHours     Decimal?                    @map("actual_hours") @db.Decimal(6, 2)
  scheduledFor    DateTime?                   @map("scheduled_for")
  startedAt       DateTime?                   @map("started_at")
  completedAt     DateTime?                   @map("completed_at")
  approvedAt      DateTime?                   @map("approved_at")
  approvedById    String?                     @map("approved_by_id")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")
  deletedAt       DateTime?                   @map("deleted_at")
  alertAfterHours Int?                        @map("alert_after_hours")
  alertSentAt     DateTime?                   @map("alert_sent_at")
  groupId         String?                     @map("group_id")
  isAvailable     Boolean                     @default(false) @map("is_available")
  maintenanceType MaintenanceType             @map("maintenance_type")
  totalCost       Decimal?                    @map("total_cost") @db.Decimal(12, 2)
  costItems       ServiceOrderCostItem[]
  attachments     Attachment[]                @relation("ServiceOrderAttachments")
  notifications   Notification[]
  comments        ServiceOrderComment[]
  statusHistory   ServiceOrderStatusHistory[]
  tasks           ServiceOrderTask[]
  technicians     ServiceOrderTechnician[]
  approvedBy      User?                       @relation("ServiceOrderApprover", fields: [approvedById], references: [id])
  client          Client?                     @relation(fields: [clientId], references: [id])
  costCenter      CostCenter?                 @relation(fields: [costCenterId], references: [id])
  equipment       Equipment?                  @relation(fields: [equipmentId], references: [id])
  group           MaintenanceGroup?           @relation(fields: [groupId], references: [id])
  location        Location?                   @relation(fields: [locationId], references: [id])
  maintenance     Maintenance?                @relation(fields: [maintenanceId], references: [id])
  requester       User                        @relation("ServiceOrderRequester", fields: [requesterId], references: [id])
  laudos          Laudo[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([companyId, clientId])
  @@index([companyId, status])
  @@index([companyId, clientId, status])
  @@index([groupId, isAvailable])
  @@index([isAvailable, createdAt])
  @@index([equipmentId, createdAt(sort: Desc), id(sort: Desc)])
  @@index([costCenterId])
  @@index([locationId])
  @@index([createdAt])
  @@map("service_orders")
}

model ServiceOrderTechnician {
  id             String                     @id @default(uuid())
  serviceOrderId String                     @map("service_order_id")
  technicianId   String                     @map("technician_id")
  role           ServiceOrderTechnicianRole @default(LEAD)
  assignedAt     DateTime                   @default(now()) @map("assigned_at")
  assumedAt      DateTime?                  @map("assumed_at")
  releasedAt     DateTime?                  @map("released_at")
  serviceOrder   ServiceOrder               @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  technician     User                       @relation(fields: [technicianId], references: [id])

  @@unique([serviceOrderId, technicianId])
  @@index([technicianId])
  @@index([serviceOrderId])
  @@map("service_order_technicians")
}

model ServiceOrderStatusHistory {
  id             String              @id @default(uuid())
  serviceOrderId String              @map("service_order_id")
  fromStatus     ServiceOrderStatus? @map("from_status")
  toStatus       ServiceOrderStatus  @map("to_status")
  changedById    String              @map("changed_by_id")
  reason         String?
  createdAt      DateTime            @default(now()) @map("created_at")
  changedBy      User                @relation(fields: [changedById], references: [id])
  serviceOrder   ServiceOrder        @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}

model ServiceOrderCostItem {
  id             String        @id @default(uuid())
  serviceOrderId String        @map("service_order_id")
  description    String
  type           CostItemType
  quantity       Decimal       @db.Decimal(10, 3)
  unitPrice      Decimal       @map("unit_price") @db.Decimal(12, 2)
  totalPrice     Decimal       @map("total_price") @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  serviceOrder   ServiceOrder  @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_cost_items")
}

model ServiceOrderComment {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  authorId       String       @map("author_id")
  content        String
  isInternal     Boolean      @default(false) @map("is_internal")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  attachments    Attachment[] @relation("CommentAttachments")
  author         User         @relation(fields: [authorId], references: [id])
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_comments")
}

model ServiceOrderTask {
  id             String       @id @default(uuid())
  serviceOrderId String       @map("service_order_id")
  assignedToId   String?      @map("assigned_to_id")
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  position       Int          @default(0)
  dueDate        DateTime?    @map("due_date")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId, status])
  @@map("service_order_tasks")
}

model EquipmentMovement {
  id                    String         @id @default(uuid())
  companyId             String         @map("company_id")
  equipmentId           String         @map("equipment_id")
  requesterId           String         @map("requester_id")
  approverId            String?        @map("approver_id")
  type                  MovementType
  status                MovementStatus @default(ACTIVE)
  originLocationId      String         @map("origin_location_id")
  destinationLocationId String         @map("destination_location_id")
  reason                String?
  expectedReturnAt      DateTime?      @map("expected_return_at")
  returnedAt            DateTime?      @map("returned_at")
  notes                 String?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  approver              User?          @relation("MovementApprover", fields: [approverId], references: [id])
  destination           Location       @relation("MovementDestination", fields: [destinationLocationId], references: [id])
  equipment             Equipment      @relation(fields: [equipmentId], references: [id])
  origin                Location       @relation("MovementOrigin", fields: [originLocationId], references: [id])
  requester             User           @relation("MovementRequester", fields: [requesterId], references: [id])

  @@index([companyId])
  @@index([equipmentId, status])
  @@map("equipment_movements")
}

model Attachment {
  id             String               @id @default(uuid())
  companyId      String               @map("company_id")
  clientId       String?              @map("client_id")
  entity         AttachmentEntity
  fileName       String               @map("file_name")
  storedName     String               @map("stored_name")
  bucket         String
  key            String
  mimeType       String               @map("mime_type")
  sizeBytes      Int                  @map("size_bytes")
  uploadedById   String               @map("uploaded_by_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  commentId      String?              @map("comment_id")
  equipmentId    String?              @map("equipment_id")
  maintenanceId  String?              @map("maintenance_id")
  serviceOrderId String?              @map("service_order_id")
  comment        ServiceOrderComment? @relation("CommentAttachments", fields: [commentId], references: [id])
  equipment      Equipment?           @relation("EquipmentAttachments", fields: [equipmentId], references: [id])
  maintenance    Maintenance?         @relation("MaintenanceAttachments", fields: [maintenanceId], references: [id])
  serviceOrder   ServiceOrder?        @relation("ServiceOrderAttachments", fields: [serviceOrderId], references: [id])

  @@index([serviceOrderId])
  @@index([maintenanceId])
  @@index([equipmentId])
  @@index([companyId, entity])
  @@index([bucket, key])
  @@map("attachments")
}

model Notification {
  id             String              @id @default(uuid())
  companyId      String              @map("company_id")
  userId         String              @map("user_id")
  serviceOrderId String?             @map("service_order_id")
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  title          String
  body           String
  metadata       Json?
  sentAt         DateTime?           @map("sent_at")
  failedAt       DateTime?           @map("failed_at")
  failReason     String?             @map("fail_reason")
  retryCount     Int                 @default(0) @map("retry_count")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  serviceOrder   ServiceOrder?       @relation(fields: [serviceOrderId], references: [id])
  user           User                @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([status, createdAt])
  @@index([companyId, createdAt])
  @@map("notifications")
}

model AlertRule {
  id                String              @id @default(uuid())
  companyId         String              @map("company_id")
  createdById       String              @map("created_by_id")
  name              String
  description       String?
  isActive          Boolean             @default(true) @map("is_active")
  triggerEvent      EventType           @map("trigger_event")
  conditions        Json                @default("[]")
  headerColor       String              @default("#6366F1") @map("header_color")
  headerTitle       String              @map("header_title")
  bodyTemplate      String              @map("body_template")
  tableFields       Json                @default("[]") @map("table_fields")
  buttonLabel       String?             @map("button_label")
  buttonUrlTemplate String?             @map("button_url_template")
  footerNote        String?             @map("footer_note")
  recipientRoles    UserRole[]          @map("recipient_roles")
  recipientGroupIds String[]            @map("recipient_group_ids")
  recipientUserIds  String[]            @map("recipient_user_ids")
