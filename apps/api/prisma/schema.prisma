  @@unique([companyId, name])
  @@index([companyId])
  @@map("custom_roles")
}

model CustomRolePermission {
  id           String     @id @default(uuid())
  customRoleId String     @map("custom_role_id")
  resource     String
  action       String
  customRole   CustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, resource, action])
  @@index([customRoleId])
  @@map("custom_role_permissions")
}

model LoginAttempt {
  id         String   @id @default(uuid())
  email      String
  userId     String?  @map("user_id")
  success    Boolean
  ipAddress  String   @map("ip_address")
  userAgent  String?  @map("user_agent")
  country    String?
  region     String?
  city       String?
  latitude   Float?
  longitude  Float?
  failReason String?  @map("fail_reason")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model AccountBlock {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  ipAddress   String?   @map("ip_address")
  reason      String
  blockedAt   DateTime  @default(now()) @map("blocked_at")
  expiresAt   DateTime  @map("expires_at")
  unblocked   Boolean   @default(false)
  unblockedAt DateTime? @map("unblocked_at")
  unblockedBy String?   @map("unblocked_by")
