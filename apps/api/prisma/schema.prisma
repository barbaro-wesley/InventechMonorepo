// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — Sistema de Gestão de Manutenção e Equipamentos
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  COMPANY_MANAGER
  TECHNICIAN
  CLIENT_ADMIN
  CLIENT_USER
  CLIENT_VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BLOCKED     // Bloqueado por tentativas excessivas
  UNVERIFIED  // Email não verificado
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TRIAL
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SCRAPPED
  BORROWED
}

enum EquipmentCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INITIAL_ACCEPTANCE
  EXTERNAL_SERVICE
  TECHNOVIGILANCE
  TRAINING
  IMPROPER_USE
  DEACTIVATION
}

enum RecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

enum ServiceOrderStatus {
  OPEN
  AWAITING_PICKUP
  IN_PROGRESS
  COMPLETED
  COMPLETED_APPROVED
  COMPLETED_REJECTED
  CANCELLED
}

enum ServiceOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ServiceOrderTechnicianRole {
  LEAD
  ASSISTANT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum MovementType {
  TRANSFER
  LOAN
}

enum MovementStatus {
  ACTIVE
  RETURNED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  TELEGRAM
  WEBSOCKET
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum AttachmentEntity {
  EQUIPMENT
  SERVICE_ORDER
  MAINTENANCE
  INVOICE
  AVATAR
  COMMENT
}

enum ReportType {
  SERVICE_ORDERS
  EQUIPMENT
  PREVENTIVE
  TECHNICIANS
  FINANCIAL
}

// Permissões de relatório por empresa — quais roles acessam cada tipo
// Configurado pelo COMPANY_ADMIN no painel de administração

enum TwoFactorType {
  LOGIN
  EMAIL_CHANGE
  PASSWORD_RESET
  SENSITIVE_ACTION
}

// ─────────────────────────────────────────────────────────────────────────────
// PLATFORM
// ─────────────────────────────────────────────────────────────────────────────

model Platform {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  companies Company[]

  @@map("platforms")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMPANY
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id          String        @id @default(uuid())
  platformId  String        @map("platform_id")
  name        String
  slug        String        @unique
  document    String?       @unique
  email       String?
  phone       String?
  logoUrl     String?       @map("logo_url")
  // Configurações de relatório
  reportPrimaryColor   String?  @default("#1E40AF") @map("report_primary_color")
  reportSecondaryColor String?  @default("#DBEAFE") @map("report_secondary_color")
  reportHeaderTitle    String?  @map("report_header_title")  // Ex: "Relatório Técnico"
  reportFooterText     String?  @map("report_footer_text")   // Ex: "Documento confidencial"
  status      CompanyStatus @default(ACTIVE)
  trialEndsAt DateTime?     @map("trial_ends_at")
  settings    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  platform Platform @relation(fields: [platformId], references: [id])

  clients           Client[]
  users             User[]
  maintenanceGroups MaintenanceGroup[]
  reportPermissions ReportPermission[]
  licenseExpiresAt  DateTime?   // data de vencimento do contrato
  suspendedAt       DateTime?   // quando foi suspenso
  suspendedReason   String?     // motivo do bloqueio
  suspendedBy       String?     // ID do SUPER_ADMIN que bloqueou
  @@index([platformId])
  @@index([slug])
  @@index([status])
  @@map("companies")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENT
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String       @id @default(uuid())
  companyId String       @map("company_id")
  name      String
  document  String?
  email     String?
  phone     String?
  address   Json?
  logoUrl   String?      @map("logo_url")       // Logo do cliente para relatórios
  reportName String?     @map("report_name")     // Nome que aparece nos relatórios
  status    ClientStatus @default(ACTIVE)
  settings  Json?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id])

  users         User[]
  costCenters   CostCenter[]
  locations     Location[]
  equipments    Equipment[]
  serviceOrders ServiceOrder[]
  maintenances  Maintenance[]
  schedules     MaintenanceSchedule[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(uuid())
  companyId      String?    @map("company_id")
  clientId       String?    @map("client_id")
  name           String
  email          String     @unique
  passwordHash   String     @map("password_hash")
  role           UserRole
  status         UserStatus @default(ACTIVE)
  avatarUrl      String?    @map("avatar_url")
  phone          String?
  telegramChatId String?    @map("telegram_chat_id")
  lastLoginAt    DateTime?  @map("last_login_at")
  lastLoginIp    String?    @map("last_login_ip")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  company Company? @relation(fields: [companyId], references: [id])
  client  Client?  @relation(fields: [clientId], references: [id])

  refreshTokens           RefreshToken[]
  serviceOrdersOwned      ServiceOrder[]            @relation("ServiceOrderRequester")
  serviceOrdersApproved   ServiceOrder[]            @relation("ServiceOrderApprover")
  serviceOrderTechnicians ServiceOrderTechnician[]
  comments                ServiceOrderComment[]
  taskAssignments         ServiceOrderTask[]
  notifications           Notification[]
  movementsRequested      EquipmentMovement[]       @relation("MovementRequester")
  movementsApproved       EquipmentMovement[]       @relation("MovementApprover")
  maintenancesExecuted    Maintenance[]
  technicianGroups        TechnicianGroup[]
  loginAttempts           LoginAttempt[]
  accountBlocks           AccountBlock[]
  twoFactorCodes          TwoFactorCode[]
  emailVerifications      EmailVerification[]
  passwordResets          PasswordReset[]

  @@index([companyId])
  @@index([clientId])
  @@index([companyId, clientId])
  @@index([email])
  @@index([role])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// REFRESH TOKEN
// ─────────────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE GROUP
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceGroup {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  description String?
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  technicians   TechnicianGroup[]
  serviceOrders ServiceOrder[]
  schedules     MaintenanceSchedule[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
  @@map("maintenance_groups")
}

// ─────────────────────────────────────────────────────────────────────────────
// TECHNICIAN GROUP
// ─────────────────────────────────────────────────────────────────────────────

model TechnicianGroup {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  groupId    String   @map("group_id")
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  group MaintenanceGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId, isActive])
  @@map("technician_groups")
}

// ─────────────────────────────────────────────────────────────────────────────
// COST CENTER
// ─────────────────────────────────────────────────────────────────────────────

model CostCenter {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  clientId    String   @map("client_id")
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  equipments Equipment[]

  @@unique([clientId, code])
  @@index([companyId, clientId])
  @@map("cost_centers")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOCATION
// ─────────────────────────────────────────────────────────────────────────────

model Location {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  clientId    String   @map("client_id")
  name        String
  parentId    String?  @map("parent_id")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client   Client     @relation(fields: [clientId], references: [id])
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  equipments        Equipment[]
  movementsFrom     EquipmentMovement[] @relation("MovementOrigin")
  movementsTo       EquipmentMovement[] @relation("MovementDestination")
  currentEquipments Equipment[]         @relation("CurrentLocation")

  @@index([companyId, clientId])
  @@index([clientId, parentId])
  @@map("locations")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT TYPE / SUBTYPE
// ─────────────────────────────────────────────────────────────────────────────

model EquipmentType {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  subtypes   EquipmentSubtype[]
  equipments Equipment[]

  @@index([companyId])
  @@map("equipment_types")
}

model EquipmentSubtype {
  id          String   @id @default(uuid())
  typeId      String   @map("type_id")
  companyId   String   @map("company_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  type       EquipmentType @relation(fields: [typeId], references: [id])
  equipments Equipment[]

  @@index([typeId])
  @@index([companyId])
  @@map("equipment_subtypes")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT
// ─────────────────────────────────────────────────────────────────────────────

model Equipment {
  id                   String               @id @default(uuid())
  companyId            String               @map("company_id")
  clientId             String               @map("client_id")
  costCenterId         String?              @map("cost_center_id")
  locationId           String?              @map("location_id")
  currentLocationId    String?              @map("current_location_id")
  typeId               String?              @map("type_id")
  subtypeId            String?              @map("subtype_id")
  name                 String
  brand                String?
  model                String?
  serialNumber         String?              @map("serial_number")
  patrimonyNumber      String?              @map("patrimony_number")
  anvisaNumber         String?              @map("anvisa_number")
  purchaseValue        Decimal?             @map("purchase_value")    @db.Decimal(12, 2)
  purchaseDate         DateTime?            @map("purchase_date")     @db.Date
  invoiceNumber        String?              @map("invoice_number")
  warrantyStart        DateTime?            @map("warranty_start")    @db.Date
  warrantyEnd          DateTime?            @map("warranty_end")      @db.Date
  depreciationRate     Decimal?             @map("depreciation_rate") @db.Decimal(5, 2)
  currentValue         Decimal?             @map("current_value")     @db.Decimal(12, 2)
  lastDepreciationCalc DateTime?            @map("last_depreciation_calc")
  ipAddress            String?              @map("ip_address")
  operatingSystem      String?              @map("operating_system")
  btus                 Int?
  voltage              String?
  power                String?
  status               EquipmentStatus      @default(ACTIVE)
  criticality          EquipmentCriticality @default(MEDIUM)
  observations         String?
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  deletedAt            DateTime?            @map("deleted_at")

  client          Client            @relation(fields: [clientId], references: [id])
  costCenter      CostCenter?       @relation(fields: [costCenterId], references: [id])
  location        Location?         @relation(fields: [locationId], references: [id])
  currentLocation Location?         @relation("CurrentLocation", fields: [currentLocationId], references: [id])
  type            EquipmentType?    @relation(fields: [typeId], references: [id])
  subtype         EquipmentSubtype? @relation(fields: [subtypeId], references: [id])

  serviceOrders ServiceOrder[]
  maintenances  Maintenance[]
  movements     EquipmentMovement[]
  schedules     MaintenanceSchedule[]
  attachments   Attachment[]          @relation("EquipmentAttachments")

  @@index([companyId, clientId])
  @@index([clientId, status])
  @@index([clientId, typeId])
  @@index([serialNumber])
  @@index([patrimonyNumber])
  @@map("equipments")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE SCHEDULE
// ─────────────────────────────────────────────────────────────────────────────

model MaintenanceSchedule {
  id                   String          @id @default(uuid())
  companyId            String          @map("company_id")
  clientId             String          @map("client_id")
  equipmentId          String          @map("equipment_id")
  groupId              String?         @map("group_id")
  title                String
  description          String?
  maintenanceType      MaintenanceType @map("maintenance_type")
  recurrenceType       RecurrenceType  @map("recurrence_type")
  customIntervalDays   Int?            @map("custom_interval_days")
  estimatedDurationMin Int?            @map("estimated_duration_min")
  assignedTechnicianId String?         @map("assigned_technician_id")
  startDate            DateTime        @map("start_date") @db.Date
  endDate              DateTime?       @map("end_date")   @db.Date
  nextRunAt            DateTime        @map("next_run_at")
  lastRunAt            DateTime?       @map("last_run_at")
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  client    Client            @relation(fields: [clientId], references: [id])
  equipment Equipment         @relation(fields: [equipmentId], references: [id])
  group     MaintenanceGroup? @relation(fields: [groupId], references: [id])

  maintenances Maintenance[]

  @@index([companyId, clientId])
  @@index([nextRunAt, isActive])
  @@index([equipmentId])
  @@map("maintenance_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────────────────────────────────────────

model Maintenance {
  id           String          @id @default(uuid())
  companyId    String          @map("company_id")
  clientId     String          @map("client_id")
  equipmentId  String          @map("equipment_id")
  scheduleId   String?         @map("schedule_id")
  technicianId String?         @map("technician_id")
  type         MaintenanceType
  title        String
  description  String?
  scheduledAt  DateTime?       @map("scheduled_at")
  startedAt    DateTime?       @map("started_at")
  completedAt  DateTime?       @map("completed_at")
  observations String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  client     Client               @relation(fields: [clientId], references: [id])
  equipment  Equipment            @relation(fields: [equipmentId], references: [id])
  schedule   MaintenanceSchedule? @relation(fields: [scheduleId], references: [id])
  technician User?                @relation(fields: [technicianId], references: [id])

  serviceOrders ServiceOrder[]
  attachments   Attachment[]   @relation("MaintenanceAttachments")

  @@index([companyId, clientId])
  @@index([equipmentId])
  @@index([scheduleId])
  @@index([technicianId])
  @@map("maintenances")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrder {
  id              String               @id @default(uuid())
  companyId       String               @map("company_id")
  clientId        String               @map("client_id")
  equipmentId     String               @map("equipment_id")
  maintenanceId   String?              @map("maintenance_id")
  requesterId     String               @map("requester_id")
  approvedById    String?              @map("approved_by_id")
  groupId         String?              @map("group_id")
  number          Int
  title           String
  description     String
  maintenanceType MaintenanceType      @map("maintenance_type")
  status          ServiceOrderStatus   @default(OPEN)
  priority        ServiceOrderPriority @default(MEDIUM)
  resolution      String?
  internalNotes   String?              @map("internal_notes")
  estimatedHours  Decimal?             @map("estimated_hours") @db.Decimal(6, 2)
  actualHours     Decimal?             @map("actual_hours")    @db.Decimal(6, 2)
  scheduledFor    DateTime?            @map("scheduled_for")
  startedAt       DateTime?            @map("started_at")
  completedAt     DateTime?            @map("completed_at")
  approvedAt      DateTime?            @map("approved_at")
  isAvailable     Boolean              @default(false) @map("is_available")
  alertAfterHours Int?                 @map("alert_after_hours")
  alertSentAt     DateTime?            @map("alert_sent_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  deletedAt       DateTime?            @map("deleted_at")

  client      Client            @relation(fields: [clientId], references: [id])
  equipment   Equipment         @relation(fields: [equipmentId], references: [id])
  maintenance Maintenance?      @relation(fields: [maintenanceId], references: [id])
  requester   User              @relation("ServiceOrderRequester", fields: [requesterId], references: [id])
  approvedBy  User?             @relation("ServiceOrderApprover", fields: [approvedById], references: [id])
  group       MaintenanceGroup? @relation(fields: [groupId], references: [id])

  technicians   ServiceOrderTechnician[]
  comments      ServiceOrderComment[]
  tasks         ServiceOrderTask[]
  attachments   Attachment[]              @relation("ServiceOrderAttachments")
  statusHistory ServiceOrderStatusHistory[]
  notifications Notification[]

  @@unique([companyId, number])
  @@index([companyId, clientId])
  @@index([clientId, status])
  @@index([groupId, isAvailable])
  @@index([isAvailable, createdAt])
  @@index([equipmentId])
  @@index([createdAt])
  @@map("service_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER TECHNICIAN
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderTechnician {
  id             String                     @id @default(uuid())
  serviceOrderId String                     @map("service_order_id")
  technicianId   String                     @map("technician_id")
  role           ServiceOrderTechnicianRole @default(LEAD)
  assignedAt     DateTime                   @default(now()) @map("assigned_at")
  assumedAt      DateTime?                  @map("assumed_at")
  releasedAt     DateTime?                  @map("released_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  technician   User         @relation(fields: [technicianId], references: [id])

  @@unique([serviceOrderId, technicianId])
  @@index([technicianId])
  @@index([serviceOrderId])
  @@map("service_order_technicians")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER STATUS HISTORY
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderStatusHistory {
  id             String              @id @default(uuid())
  serviceOrderId String              @map("service_order_id")
  fromStatus     ServiceOrderStatus? @map("from_status")
  toStatus       ServiceOrderStatus  @map("to_status")
  changedById    String              @map("changed_by_id")
  reason         String?
  createdAt      DateTime            @default(now()) @map("created_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER COMMENT
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderComment {
  id             String   @id @default(uuid())
  serviceOrderId String   @map("service_order_id")
  authorId       String   @map("author_id")
  content        String
  isInternal     Boolean  @default(false) @map("is_internal")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])
  attachments  Attachment[] @relation("CommentAttachments")

  @@index([serviceOrderId])
  @@map("service_order_comments")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE ORDER TASK
// ─────────────────────────────────────────────────────────────────────────────

model ServiceOrderTask {
  id             String     @id @default(uuid())
  serviceOrderId String     @map("service_order_id")
  assignedToId   String?    @map("assigned_to_id")
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  position       Int        @default(0)
  dueDate        DateTime?  @map("due_date")
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])

  @@index([serviceOrderId, status])
  @@map("service_order_tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// EQUIPMENT MOVEMENT
// ─────────────────────────────────────────────────────────────────────────────

model EquipmentMovement {
  id                    String         @id @default(uuid())
  companyId             String         @map("company_id")
  clientId              String         @map("client_id")
  equipmentId           String         @map("equipment_id")
  requesterId           String         @map("requester_id")
  approverId            String?        @map("approver_id")
  type                  MovementType
  status                MovementStatus @default(ACTIVE)
  originLocationId      String         @map("origin_location_id")
  destinationLocationId String         @map("destination_location_id")
  reason                String?
  expectedReturnAt      DateTime?      @map("expected_return_at")
  returnedAt            DateTime?      @map("returned_at")
  notes                 String?
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  requester   User      @relation("MovementRequester", fields: [requesterId], references: [id])
  approver    User?     @relation("MovementApprover", fields: [approverId], references: [id])
  origin      Location  @relation("MovementOrigin", fields: [originLocationId], references: [id])
  destination Location  @relation("MovementDestination", fields: [destinationLocationId], references: [id])

  @@index([companyId, clientId])
  @@index([equipmentId, status])
  @@map("equipment_movements")
}

// ─────────────────────────────────────────────────────────────────────────────
// ATTACHMENT
// FKs específicas por entidade — apenas uma preenchida por vez
// conforme o campo `entity`.
// ─────────────────────────────────────────────────────────────────────────────

model Attachment {
  id           String           @id @default(uuid())
  companyId    String           @map("company_id")
  clientId     String?          @map("client_id")
  entity       AttachmentEntity
  fileName     String           @map("file_name")
  storedName   String           @map("stored_name")
  bucket       String
  key          String
  mimeType     String           @map("mime_type")
  sizeBytes    Int              @map("size_bytes")
  uploadedById String           @map("uploaded_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")

  // Apenas um destes será preenchido por vez
  serviceOrderId String?  @map("service_order_id")
  maintenanceId  String?  @map("maintenance_id")
  equipmentId    String?  @map("equipment_id")
  commentId      String?  @map("comment_id")

  serviceOrder ServiceOrder?        @relation("ServiceOrderAttachments", fields: [serviceOrderId], references: [id])
  maintenance  Maintenance?         @relation("MaintenanceAttachments", fields: [maintenanceId], references: [id])
  equipment    Equipment?           @relation("EquipmentAttachments", fields: [equipmentId], references: [id])
  comment      ServiceOrderComment? @relation("CommentAttachments", fields: [commentId], references: [id])

  @@index([serviceOrderId])
  @@index([maintenanceId])
  @@index([equipmentId])
  @@index([companyId, entity])
  @@index([bucket, key])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id             String              @id @default(uuid())
  companyId      String              @map("company_id")
  userId         String              @map("user_id")
  serviceOrderId String?             @map("service_order_id")
  channel        NotificationChannel
  status         NotificationStatus  @default(PENDING)
  title          String
  body           String
  metadata       Json?
  sentAt         DateTime?           @map("sent_at")
  failedAt       DateTime?           @map("failed_at")
  failReason     String?             @map("fail_reason")
  retryCount     Int                 @default(0) @map("retry_count")
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id])

  @@index([userId, readAt])
  @@index([status, createdAt])
  @@index([companyId, createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORT PERMISSION — controle de acesso por tipo de relatório
// ─────────────────────────────────────────────────────────────────────────────

model ReportPermission {
  id         String     @id @default(uuid())
  companyId  String     @map("company_id")
  reportType ReportType @map("report_type")
  // Roles que têm acesso — ex: ["COMPANY_ADMIN", "COMPANY_MANAGER"]
  allowedRoles String[] @map("allowed_roles")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, reportType])
  @@index([companyId])
  @@map("report_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOGIN ATTEMPT — Auditoria e bloqueio de conta
// ─────────────────────────────────────────────────────────────────────────────

model LoginAttempt {
  id          String   @id @default(uuid())
  email       String   // Email tentado (pode não existir no sistema)
  userId      String?  @map("user_id") // Preenchido se o email existir
  success     Boolean
  ipAddress   String   @map("ip_address")
  userAgent   String?  @map("user_agent")
  // Geolocalização do IP
  country     String?
  region      String?
  city        String?
  latitude    Float?
  longitude   Float?
  // Motivo da falha
  failReason  String?  @map("fail_reason") // WRONG_PASSWORD, USER_NOT_FOUND, ACCOUNT_BLOCKED etc.
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACCOUNT BLOCK — Bloqueio temporário após tentativas excessivas
// ─────────────────────────────────────────────────────────────────────────────

model AccountBlock {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  ipAddress   String?   @map("ip_address")
  reason      String    // Motivo do bloqueio
  blockedAt   DateTime  @default(now()) @map("blocked_at")
  expiresAt   DateTime  @map("expires_at") // Null = bloqueio permanente
  unblocked   Boolean   @default(false)
  unblockedAt DateTime? @map("unblocked_at")
  unblockedBy String?   @map("unblocked_by") // Admin que desbloqueou

  user User @relation(fields: [userId], references: [id])

  @@index([userId, unblocked])
  @@index([expiresAt])
  @@map("account_blocks")
}

// ─────────────────────────────────────────────────────────────────────────────
// TWO FACTOR AUTH — Código de verificação em duas etapas
// ─────────────────────────────────────────────────────────────────────────────

model TwoFactorCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String   // Hash do código de 6 dígitos
  type      TwoFactorType
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("two_factor_codes")
}

// ─────────────────────────────────────────────────────────────────────────────
// EMAIL VERIFICATION — Verificação de email no cadastro
// ─────────────────────────────────────────────────────────────────────────────

model EmailVerification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique // Token de verificação
  expiresAt DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// PASSWORD RESET — Recuperação de senha
// ─────────────────────────────────────────────────────────────────────────────

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique // Token de reset (hash)
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_resets")
}
