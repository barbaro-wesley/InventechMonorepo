  expiresAt DateTime      @map("expires_at")
  usedAt    DateTime?     @map("used_at")
  ipAddress String?       @map("ip_address")
  createdAt DateTime      @default(now()) @map("created_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
