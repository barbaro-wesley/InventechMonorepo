{
    "name": "inventech-monorepo",
    "version": "0.0.1",
    "private": true,
    "packageManager": "npm@10.9.2",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "dev:api": "turbo dev --filter=api",
        "dev:web": "turbo dev --filter=web",
        "build": "turbo build",
        "lint": "turbo lint",
        "clean": "turbo clean"
    },
    "devDependencies": {
        "turbo": "^2.3.3",
        "typescript": "^5.7.2",
        "prettier": "^3.4.2"
    },
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    }
}